# GEMINI_API_KEY（开发者兜底，Tier A）：用于「当日名称」「日记意义总结」等轻量能力。
# 直连构建时会被注入前端，存在暴露风险；生产推荐代理（见 VITE_GEMINI_PROXY_URL）。
# 聊天、随机日程、按标签/角色 AI 总结、人生章节（Tier B）仅使用用户在「设置」里填写的自己的 API Key，不走此变量。
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# 可选：使用代理后 API Key 不进入前端。开发时在项目根目录另开终端运行 npm run proxy，再设置此项并重启 dev。
# VITE_GEMINI_PROXY_URL=/api/gemini

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase (required for cross-device sync)
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Cloudflare Turnstile (required when CAPTCHA is enabled in Supabase Auth)
# Get keys from https://dash.cloudflare.com/ → Turnstile
# For localhost testing use: 1x00000000000000000000AA (add test secret to Supabase too)
VITE_TURNSTILE_SITE_KEY=""
